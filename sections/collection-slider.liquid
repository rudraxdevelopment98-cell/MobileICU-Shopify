<style> 
.collection-slider-wrapper {
  padding: 40px 20px;
  overflow: hidden;
}

.page-width {
  {% comment %} max-width: 100%; {% endcomment %}
  {% comment %} padding: 0 20px; {% endcomment %}
  padding-left: 20px;
  padding-right: 20px;
}

.collection-title {
  font-size: 32px;
  font-weight: bold;
  margin-bottom: 20px;
}

.collection-slider {
  display: flex;
}

.collection-card {
  border: 1px solid #ffef8f;
  border-radius: 10px;
  text-align: center;
  background: #fdfdfd;
  padding: 15px 10px;
  margin: 0 5px;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.collection-image {
  width: 100%;
  position: relative;
  padding-top: 100%; /* 1:1 aspect ratio */
  overflow: hidden;
  border-radius: 6px;
  margin-bottom: 10px;
}

.collection-image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 6px;
}

.collection-info {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.collection-info h3 {
  font-size: 16px;
  margin: 10px 0;
  font-weight: 600;
}
img.shop-icon {
    padding: 0 5px;
}
.shop-btn {
  display: inline-block;
  background: #ffd600;
  padding: 6px 15px;
  border-radius: 25px;
  font-weight: 600;
  font-size: 14px;
  color: #000;
  text-decoration: none;
  margin-top: auto;
  align-items: center;
  display: flex;
  justify-content: center;
  align-content: center;
  width: 50%;
  margin: 0 auto;
  border: 1px solid transparent !important;
}
.shop-btn:hover {
  background-color: #fff;
  border: 1px solid #000 !important;
}
{% comment %} .slick-prev:before,
.slick-next:before {
  color: black;
} {% endcomment %}

.slick-prev-custom,
.slick-next-custom {
  background: none;
  border: none;
  padding: 0;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  cursor: pointer;
}

.slick-prev-custom {
  left: -14px; /* Adjust as needed */
}

.slick-next-custom {
  right: -28px; /* Adjust as needed */
}

.slick-prev-custom img,
.slick-next-custom img {
  width: 50px; /* Adjust icon size as needed */
  height: auto;
}
</style>

<section class="collection-slider-wrapper">
  <div class="page-width">
    <h2 class="collection-title">{{ section.settings.title }}</h2>
    <div class="collection-slider">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        <div class="collection-card">
          <div class="collection-image">
            {% if collection.image %}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title }}" width="" height="">
            {% elsif collection.featured_image %}
              <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title }}" width="" height="">
            {% else %}
              <img src="https://projects.codersh.com/b2b/wp-content/uploads/2024/08/woocommerce-placeholder.png" alt="{{ collection.title }}" width="" height="">
            {% endif %}
          </div>
          <div class="collection-info">
            <h3>{{ collection.title }}</h3>
            <a href="{{ collection.url }}" class="shop-btn">
              <img src="https://cdn.shopify.com/s/files/1/0965/2351/8246/files/shopping-bag_1.png?v=1754548683" alt="Bag" class="shop-icon" width="" height="">Shop</a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "collection-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Products"
    }
  ],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Collection Slider",
      "category": "Custom",
      "blocks": []
    }
  ]
}
{% endschema %}
