{% style %}
    .hero-banner__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* color: white; */
    padding: 20px 5rem;
    /* flex-wrap: wrap; */
  }

  /* .hero-banner__content,.hero-banner__image {
    width: 50%;
  } */
 .hero-banner__content {
    max-width: 700px;
  }
  .hero-banner__image {
    max-width: 570px;
  }
  .hero-banner__rating {
    font-size: 24px;
    font-weight: 300;
    margin-bottom: 10px;
  }

  .hero-banner__rating .stars {
    margin-right: 8px;
    color: #ffd700;
  }

  .hero-banner__heading {
    font-size: 64px;
    font-weight: 700;
    margin: 0;
  }

  .hero-banner__subheading {
    margin: 15px 0 30px;
    font-size: 24px;
    text-transform: uppercase;
  }

  .hero-banner__buttons a {
    display: inline-flex;
    padding: 12px 25px;
    /* border-radius: 9999px; */
    font-weight: 500;
    text-decoration: none;
    margin-right: 15px;
    transition: background 0.3s;
    gap: 4px;
  }

  /* .hero-banner__buttons a:hover {
    background: #d4d4d4;
  } */

  .banner_image {
    max-width: 100%;
    width: 100%;
    height: auto;
  }
  img.image-shadow {
    width: 100%;
    position: absolute;
    left: -8%;
    bottom: -12%;
  }
  .hero-banner__image{position: relative;}
  @media only screen and (max-width:1024px){
    .hero-banner__rating {font-size: 16px;}
    .hero-banner__heading {font-size: 50px;}
    .hero-banner__subheading {font-size: 14px;}
  }
  @media only screen and (max-width:990px){
   /* .hero-banner__wrapper {flex-direction: column-reverse;padding: 3rem 1.5rem 5rem;}
    .hero-banner__image {max-width: 400px;}
    .hero-banner__content {
      display: flex;
      flex-direction: column;
      align-items: center;
    } */
    .hero-banner__content {max-width: 450px;}
    h2.hero-banner__heading {font-size: 40px;}
    .hero-banner__wrapper.page-width {padding: 3rem 1.5rem;}
    .hero-banner__image {max-width: 300px;}
    .hero-banner__buttons a {min-height: initial;padding: 10px 14px;font-size: 14px;}
  }
  @media only screen and (max-width:750px){
    .hero-banner__wrapper.page-width {flex-direction: column-reverse;}
    .hero-banner__content {
      max-width: 320px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    h2.hero-banner__heading {font-size: 34px;}
    .hero-banner__buttons {display: flex;justify-content: center;gap: 8px;}
    .hero-banner__buttons a{margin: 0;}
  }
{% endstyle %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-banner__wrapper page-width">
    <div class="hero-banner__content">
      <div class="hero-banner__rating">
        <span class="stars">★★★★★</span>
        <span class="rating-text">{{ section.settings.rating }}</span>
      </div>
      <h2 class="hero-banner__heading">{{ section.settings.heading }}</h2>
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
      <div class="hero-banner__buttons">
        <a href="{{ section.settings.shop_button_url }}" class="btn btn--primary button">
          {{ section.settings.shop_button_label }}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none">
            <path d="M1 7L16.75 7M11.5 13L17.5 7L11.5 1" stroke="black" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="{{ section.settings.register_button_url }}" class="btn btn--secondary button">
          {{ section.settings.register_button_label }}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none">
            <path d="M1 7L16.75 7M11.5 13L17.5 7L11.5 1" stroke="black" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
    <div class="hero-banner__image">
      {% if section.settings.banner_image != blank %}
        <img
          src="{{ section.settings.banner_image | image_url: width: 600 }}"
          alt="Hero Banner Image"
          class="banner_image"
        >
      {% endif %}
      {% if section.settings.image_shadow != blank %}
        <img src="{{ section.settings.image_shadow | img_url:'master' }}" class="image-shadow">
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "image_picker",
      "id": "image_shadow",
      "label": "Image Shadow"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating Text",
      "default": "4.9/5 Rating"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GET ANY ACCESSORIES"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "RELATED TO PHONES AND LAPTOP IN WHOLE SALE PRICE"
    },
    {
      "type": "text",
      "id": "shop_button_label",
      "label": "Shop Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "shop_button_url",
      "label": "Shop Button Link"
    },
    {
      "type": "text",
      "id": "register_button_label",
      "label": "Register Button Text",
      "default": "Register Now"
    },
    {
      "type": "url",
      "id": "register_button_url",
      "label": "Register Button Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
