{% style %}
  .about-us {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }
  h2.about-us-heading {
    margin: 0 0 2rem;
  }
  .about-us-row1,.about-us-row2{
    display: flex;
    align-items: center;
    gap: 6rem;
  }
  .about-us-content p {
    font-size: 24px;
    color: rgb(0 0 0 / 70%);
    text-align: justify;
    line-height: 35px;
  }
  .image-wrapper img{max-width: 100%;}
  .about-us-row1 .about-us-content {width: 58%;}
  .about-us-row1 .image-wrapper {width: 42%;}
  .about-us-row2 .about-us-content {width: 71.5%;}
  .about-us-row2 .image-wrapper {width: 28.5%;}
  .about-us-row2 {padding-top: 3rem;}
  @media only screen and (max-width: 1024px){
    .about-us-content p {font-size: 16px;line-height: 26px;}
  }
  @media only screen and (max-width: 990px){
    .about-us-row1{flex-direction: column;gap: 1rem;}
    .about-us-row2 {flex-direction: column-reverse;gap: 0rem;}
    .about-us-row1 .image-wrapper, .about-us-row2 .image-wrapper {width: 100%;display: flex;justify-content: center;}
    .about-us-row1 .about-us-content, .about-us-row2 .about-us-content {width: 100% !important;}
  }
  @media only screen and (max-width:750px){
    .about-us {padding-top: 2rem;padding-bottom: 0rem;}
  }
{% endstyle %}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="about-us page-width">
    <h2 class="about-us-heading h1">{{ section.settings.heading }}</h2>
    <div class="about-us-row1">
      <div class="image-wrapper">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url:'master' }}" height="auto" width="auto" class="about-us-image">
        {% endif %}
      </div>
      <div class="about-us-content">
        <p>{{ section.settings.content }}</p>
      </div>
    </div>
    <div class="about-us-row2">
      <div class="about-us-content">
        <p>{{ section.settings.content1 }}</p>
      </div>
      <div class="image-wrapper">
        {% if section.settings.image1 != blank %}
          <img src="{{ section.settings.image1 | img_url:'master' }}" height="auto" width="auto" class="about-us-image">
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "image1",
      "label": "Image"
    },
    {
      "type": "richtext",
      "id": "content1",
      "label": "Text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-3"
    }
  ],
  "presets": [
    {
      "name": "About Us",
    }
  ]
}
{% endschema %}
